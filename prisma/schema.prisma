// Per-method withdrawal configuration
// One row per CardName (BKASH, NAGAD). Seeded on first boot.
model WithdrawMethodConfig {
  id            String   @id @default(cuid())
  method        CardName @unique           // BKASH | NAGAD
  isActive      Boolean  @default(true)   // toggle visibility for users
  displayName   String                    // e.g. "bKash", "Nagad"
  logoUrl       String   @default("")     // optional icon URL
  minAmount     Decimal  @default(500)    // per-method floor
  maxAmount     Decimal  @default(50000)  // per-method ceiling
  dailyLimit    Decimal  @default(0)      // 0 = no limit
  processingFee Decimal  @default(0)      // flat fee in BDT (0 = free)
  feePercent    Decimal  @default(0)      // % fee (0 = free)
  note          String   @default("")     // shown to user at withdrawal time
  updatedAt     DateTime @updatedAt
}

// Global withdrawal configuration (singleton row, id = "singleton")
model WithdrawGlobalConfig {
  id               String   @id @default("singleton")
  minWithdraw      Decimal  @default(500)
  maxWithdraw      Decimal  @default(50000)
  autoApproveBelow Decimal  @default(0)    // 0 = never auto-approve
  requiresReview   Boolean  @default(true)
  maintenanceMode  Boolean  @default(false)
  maintenanceMsg   String   @default("Withdrawals are temporarily paused for maintenance.")
  updatedAt        DateTime @updatedAt
}


model DepositMethodConfig {
  id                String    @id @default(cuid())
  method            TrxWallet @unique           // BKASH | NAGAD
  isActive          Boolean   @default(true)    // toggle for users
  displayName       String                      // e.g. "bKash", "Nagad"
  logoUrl           String    @default("")
  minAmount         Decimal   @default(100)
  maxAmount         Decimal   @default(100000)
  bonusPercent      Decimal   @default(0)       // % bonus on each deposit (0 = none)
  firstDepositBonus Decimal   @default(0)       // flat BDT bonus for first deposit (0 = none)
  note              String    @default("")      // shown to user at deposit time
  updatedAt         DateTime  @updatedAt
}

// Global deposit configuration (singleton, id = "singleton")
model DepositGlobalConfig {
  id               String   @id @default("singleton")
  minDeposit       Decimal  @default(100)
  maxDeposit       Decimal  @default(100000)
  autoApproveBelow Decimal  @default(0)     // 0 = never auto-approve
  requiresReview   Boolean  @default(true)
  maintenanceMode  Boolean  @default(false)
  maintenanceMsg   String   @default("Deposits are temporarily paused for maintenance.")
  bonusEnabled     Boolean  @default(true)  // master switch for all bonuses
  updatedAt        DateTime @updatedAt
}





model SiteTextContent {
  id               String   @id @default("singleton")
  headLine         String?
}



model ForgetPasswordOtp {
  id                 String    @id @default(cuid())
  code        String
  expiry      DateTime
  phone       String @unique
}


model ChangePasswordAccessToken{
  id                 String    @id @default(cuid())
  expiry      DateTime
    phone       String @unique
}



// Stores the global rebate configuration (singleton)
model BettingRebateConfig {
  id          String   @id @default("singleton")
  percent     Decimal  @default(0.05)   // e.g. 0.05 = 5% of referral's loss
  isEnabled   Boolean  @default(true)
  minLoss     Decimal  @default(0)      // minimum referral loss to qualify (0 = no minimum)
  description String   @default("")     // admin note
  updatedAt   DateTime @updatedAt
}

// One record per dispatch run — tracks when it happened and what was included
model RebateDispatch {
  id              String               @id @default(cuid())
  percent         Decimal              // % used for this dispatch
  periodStart     DateTime             // loss counted from this date
  periodEnd       DateTime             // loss counted to this date (dispatch time)
  totalLoss       Decimal              @default(0)  // total referral loss in period
  totalRebate     Decimal              @default(0)  // total BDT credited
  totalReferers   Int                  @default(0)
  totalReferrals  Int                  @default(0)
  createdAt       DateTime             @default(now())
  items           RebateDispatchItem[]
}

// One row per referer per dispatch — what they received and from which referrals
model RebateDispatchItem {
  id           String         @id @default(cuid())
  dispatchId   String
  dispatch     RebateDispatch @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  refererId    String         // the user who gets the rebate
  refererName  String
  rebateAmount Decimal        // BDT credited to this referer
  totalLoss    Decimal        // sum of referral losses that generated this rebate
  referralCount Int           @default(0)  // how many valid referrals contributed
  createdAt    DateTime       @default(now())

  @@index([dispatchId])
  @@index([refererId])
}